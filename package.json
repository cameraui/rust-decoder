{
  "name": "@camera.ui/rust-decoder",
  "version": "0.0.14",
  "description": "Native Rust pixel-format conversion, resize and crop for the camera.ui ecosystem",
  "author": "seydx (https://github.com/seydx)",
  "main": "index.js",
  "types": "index.d.ts",
  "type": "commonjs",
  "napi": {
    "binaryName": "rust-decoder",
    "targets": [
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-unknown-freebsd",
      "aarch64-apple-darwin",
      "aarch64-pc-windows-msvc",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "riscv64gc-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "audit": "npm audit fix",
    "artifacts": "napi artifacts",
    "build:debug": "napi build --platform",
    "build": "napi build --platform --release",
    "clean:cargo": "cargo clean",
    "clean": "cargo clean && rimraf --glob *.node",
    "format": "prettier --write 'src/' --ignore-unknown --no-error-on-unmatched-pattern && cargo fmt",
    "install-updates": "npm i --save",
    "lint:fix": "cargo clippy --fix --allow-dirty && eslint --fix .",
    "lint": "cargo clippy && eslint .",
    "prepublishOnly": "napi prepublish --no-gh-release",
    "universal": "napi universalize",
    "update": "updates --update ./",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "9.39.2",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "set-interval-async": "^3.0.3",
    "sharp": "^0.35.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.0",
    "updates": "^17.18.0"
  },
  "bugs": {
    "url": "https://github.com/cameraui/rust-decoder/issues"
  },
  "homepage": "https://github.com/cameraui/rust-decoder#readme",
  "keywords": [
    "camera-ui",
    "decoder",
    "rust"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameraui/rust-decoder.git"
  },
  "engines": {
    "node": ">= 10"
  }
}